NODE_ENV=test
PORT=4000

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=database_name
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL="postgresql://user:password@db:5432/database_name?schema=public&connection_limit=10&pool_timeout=20"

SALT_ROUNDS=10
JWT_SECRET_KEY=secret123123
JWT_SECRET_REFRESH_KEY=secret123123
TOKEN_EXPIRE_TIME=15m
TOKEN_REFRESH_EXPIRE_TIME=7d

RATE_LIMIT_TTL=60000
RATE_LIMIT=20

LOG_LEVEL=info
LOG_MAX_FILE_SIZE=1024
